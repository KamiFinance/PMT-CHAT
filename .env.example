# ── Upstash Redis (required — message relay + auth storage) ──────────────────
# Create free database at https://upstash.com → Redis → Create Database
UPSTASH_KV_REST_API_URL=https://YOUR-DB.upstash.io
UPSTASH_KV_REST_API_TOKEN=YOUR_TOKEN_HERE

# ── Pinata IPFS (required — voice messages + file storage) ───────────────────
# Create account at https://pinata.cloud → API Keys → New Key (pinFileToIPFS)
PINATA_JWT=eyJhbGci...your_pinata_jwt

# Optional: dedicated Pinata gateway domain (faster downloads)
# PINATA_GATEWAY_DOMAIN=your-gateway.mypinata.cloud
